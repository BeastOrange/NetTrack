#!/usr/bin/env bash
# autodl-helper — wraps sshpass so we can run any command on the AutoDL host
# without retyping the password. Usage:
#
#   ./scripts/autodl run 'echo hi'
#   ./scripts/autodl rsync /local/path remote/path
#   ./scripts/autodl ssh                       # interactive shell
#
# The password lives in this file only because the user explicitly asked us to
# automate it via sshpass. If the credentials change, edit AUTODL_PASS below.

set -euo pipefail

AUTODL_HOST="autodl"
AUTODL_PASS="yORA06lqEOCy"

if [[ -z "${1:-}" ]]; then
    echo "Usage: $0 {run|ssh|rsync-up|rsync-down} [args...]"
    exit 2
fi

cmd="$1"; shift

case "$cmd" in
    run)
        sshpass -p "$AUTODL_PASS" ssh "$AUTODL_HOST" "$@"
        ;;
    ssh)
        sshpass -p "$AUTODL_PASS" ssh "$AUTODL_HOST"
        ;;
    rsync-up)
        # rsync-up <local> <remote-relative-path>
        local="$1"; remote="$2"
        sshpass -p "$AUTODL_PASS" rsync -avz --partial --info=progress2 \
            -e "ssh" \
            "$local" "$AUTODL_HOST:$remote"
        ;;
    rsync-down)
        # rsync-down <remote-relative-path> <local>
        remote="$1"; local="$2"
        sshpass -p "$AUTODL_PASS" rsync -avz --partial --info=progress2 \
            -e "ssh" \
            "$AUTODL_HOST:$remote" "$local"
        ;;
    *)
        echo "Unknown subcommand: $cmd"
        exit 2
        ;;
esac
